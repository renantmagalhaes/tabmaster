{
  "manifest_version": 3,
  "name": "Tab and Bookmark Manager",
  "version": "1.4.1",
  "description": "Manage tabs and bookmarks from a single popup.",
  "permissions": [
    "tabs",
    "bookmarks",
    "history",
    "sessions",
    "search",
    "storage"
  ],
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}
